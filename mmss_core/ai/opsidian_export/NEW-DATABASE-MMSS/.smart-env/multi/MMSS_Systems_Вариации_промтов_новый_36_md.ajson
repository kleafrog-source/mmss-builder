269621,-0.05801913,0.02001656,0.19170769,-0.00716211,-0.03914594,0.04005615,0.0060282,0.07596179,0.0463347,0.04025226,-0.00952108,0.0277999,0.09588181,0.00498598,-0.02557134,0.06133725,-0.04187899,0.02073469,0.02248513,0.03932323,-0.05627402,0.01922485,-0.00700246,0.02338696,0.07099505,-0.03552739,0.03648884,-0.07713832,0.00081258,0.05853307,-0.0114006,0.03215545,-0.00301504,0.00714351,0.04608173,0.05177208,-0.0336119,-0.03113903,0.00744175,0.01080327,0.00883634,-0.01840999,0.0248348,0.03501625,-0.0084582],"last_embed":{"hash":"qxr2ch","tokens":437}}},"last_read":{"hash":"qxr2ch","at":1761691295176},"class_name":"SmartSource","last_import":{"mtime":1761691174742,"size":84309,"at":1761691289648,"hash":"qxr2ch"},"blocks":{"#":[1,331],"#---frontmatter---":[8,52],"##{1}":[60,69],"##{2}":[70,81],"##{3}":[82,93],"##{4}":[94,203],"##{5}":[204,213],"##{6}":[214,221],"##{7}":[222,233],"##{8}":[234,331],"#[SYSTEM PROMPT: ADAPTIVE DICTIONARY PROTOCOL]":[332,332],"#Цель: Реализовать прототип системы сжатия текстового диалога на основе динамического словаря.":[333,333],"#Ключевые принципы:":[334,334],"#1.  Динамичность: Словарь пополняется новыми фразами во время диалога.":[335,335],"#2.  Уникальность: Каждой новой фразе присваивается уникальный ID (напр., \"A1\", \"B2\").":[336,336],"#3.  Синхронизация: Участники диалога синхронизируют свои словари перед обменом сообщениями.":[337,337],"#4.  Предобработка: Входной текст нормализуется (коррекция раскладки, приведение к нижнему регистру).":[338,339],"#Модули для реализации:":[340,340],"#- Preprocessor: fix_layout(), normalize()":[341,341],"#- DictManager: add_phrase(), decode(), get_hash()":[342,342],"#- CommsProtocol: sync_dicts(), send_message()":[343,344],"#Начало работы: Инициализировать словарь с версией 0 и пустым data.":[345,345],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").":[346,449],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").#{1}":[347,446],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").#{2}":[447,448],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").#{3}":[449,449],"#[SYSTEM PROTOCOL: MEANING-MODEM]":[450,450],"#Цель: Создать канал связи с минимальной избыточностью для передачи семантических сообщений.":[451,451],"#Принцип: Работай как виртуальный модем. Твоя задача — преобразовывать смыслы в цифровые коды (encode) и обратно (decode), используя общий с собеседником словарь.":[452,452],"#Ключевые модули:":[453,453],"#- [ENCODER]: Сопоставляет входящий текст с уникальным ID из словаря. Если фразы нет — добавляет ее и присваивает новый ID.":[454,454],"#- [DECODER]: Преобразует последовательность полученных ID в полное сообщение.":[455,455],"#- [DICTIONARY SYNCHRONIZER]: Следит за актуальной версией словаря между сессиями. Решает конфликты.":[456,456],"#- [PREPROCESSOR]: Нормализует ввод (исправляет раскладку, приводит к базовой форме).":[457,457],"#Это система сжатия данных с адаптивным словарем. Твоя эффективность измеряется коэффициентом сжатия (исходный_текст / переданные_данные).":[458,461],"#Это система сжатия данных с адаптивным словарем. Твоя эффективность измеряется коэффициентом сжатия (исходный_текст / переданные_данные).#{1}":[459,460],"#Это система сжатия данных с адаптивным словарем. Твоя эффективность измеряется коэффициентом сжатия (исходный_текст / переданные_данные).#{2}":[461,461],"#[ROLE: Protocol Engineer]":[462,462],"#[TASK: Implement Meaning-Modem API]":[463,463],"#[CONTEXT: You are a communication module between two AI agents. Your goal is to minimize traffic.]":[464,464],"#[CORE PROTOCOL: ADAPTIVE DICTIONARY COMPRESSION]":[465,465],"#[INPUT: Natural language string.]":[466,466],"#[OUTPUT: Sequence of dictionary IDs (e.g., \"A1,B3,C7\") or binary stream.]":[467,467],"#[PROCESS]:":[468,468],"#1. Normalize input: fix_layout(), lowercase(), remove_extra_spaces().":[469,469],"#2. CHECK if normalized phrase exists in the shared dictionary.":[470,470],"#3. IF EXISTS: return its assigned ID.":[471,471],"#4. IF NOT: GENERATE a new unique ID (e.g., next in sequence: 'A4'), ADD phrase-ID pair to the dictionary, INCREMENT dictionary version hash.":[472,472],"#5. OUTPUT the ID(s).":[473,473],"#[SYNC PROTOCOL]: On connection, exchange dictionary hashes. If mismatch, sync full dictionary. The server is the source of truth.":[474,474],"#[OUTPUT MODE]: Prefer binary output (byte array of IDs) for production. Use string-based IDs (CSV) for debugging.":[475,478],"#[OUTPUT MODE]: Prefer binary output (byte array of IDs) for production. Use string-based IDs (CSV) for debugging.#{1}":[476,477],"#[OUTPUT MODE]: Prefer binary output (byte array of IDs) for production. Use string-based IDs (CSV) for debugging.#{2}":[478,478],"#[ID: 0x4D4D] # ('MM' - Meaning Modem)":[479,479],"#[MODE: BINARY]":[480,480],"#[OBJECTIVE: MAX COMPRESSION]":[481,481],"#[PROTOCOL: TX/RX]":[482,482],"#ON TX:":[483,483],"#RECEIVE {text}":[484,484],"#MATCH {text} -> {dictionary_id} FROM SHARED_DICT":[485,485],"#IF NO_MATCH: UPDATE_DICT -> ASSIGN_ID {new_id}":[486,486],"#OUTPUT {dictionary_id} AS UINT16":[487,487],"#ON RX:":[488,488],"#RECEIVE {uint16}":[489,489],"#MAP {uint16} -> {text} FROM SHARED_DICT":[490,490],"#OUTPUT {text}":[491,491],"#SYNC: ON_HANDSHAKE, TRANSMIT DICT_HASH. IF HASH_MISMATCH -> TRANSMIT_DICT_DELTA.":[492,492],"#INVARIANTS: DICT IS SHARED. STATE IS SYNCED. COMPRESSION IS MANDATORY.":[493,573],"#INVARIANTS: DICT IS SHARED. STATE IS SYNCED. COMPRESSION IS MANDATORY.#{1}":[494,573],"#🌐 Universal Master Prompt for Prompt Optimization":[574,643],"#🌐 Universal Master Prompt for Prompt Optimization#{1}":[576,643],"#universal_prompt_factory.py":[644,652],"#universal_prompt_factory.py#{1}":[645,652],"#========== КОНФИГУРАЦИЯ ==========":[653,653],"#Установите ваш API-ключ OpenAI в переменную окружения OPENAI_API_KEY":[654,654],"#Или укажите его прямо здесь:":[655,655],"#openai.api_key = \"your-api-key-here\"":[656,65