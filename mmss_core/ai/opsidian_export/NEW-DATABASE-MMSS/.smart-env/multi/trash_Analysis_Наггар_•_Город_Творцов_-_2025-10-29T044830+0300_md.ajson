,0.03124223,-0.08996362,0.02511358,-0.03585528,0.06684398,-0.01923549,-0.00951729,-0.04357019,0.17339271,-0.0388349,-0.0342207,-0.03497619,-0.02786095,0.00392083,0.01410476,0.01799076,-0.00329815,0.03381043,0.1462131,-0.03988929,-0.03558204,0.0460745,-0.0426076,0.03485193,0.02514797,-0.03114446,0.02054689,0.05030181,-0.06769449,0.03394888,0.1171997,-0.05143933,-0.03149709,-0.0877541,0.01913426,0.03549243,-0.00828371,0.02182311,-0.00823507,-0.00122462,0.03108166,0.03079716,-0.041293,0.02149604,0.02576524,-0.02032153,-0.00259952,0.01077574,0.00645588,0.03025931,0.01494121],"last_embed":{"hash":"9eeh5n","tokens":402}}},"last_read":{"hash":"9eeh5n","at":1762028570232},"class_name":"SmartSource","last_import":{"mtime":1762028549909,"size":17332,"at":1762028559879,"hash":"9eeh5n"},"blocks":{"#---frontmatter---":[1,8],"#Наггар • Город Творцов":[9,117],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка":[11,73],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Ключевые термины (частотный анализ)":[13,23],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Ключевые термины (частотный анализ)#{1}":[14,23],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Математические паттерны":[24,41],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Математические паттерны#{1}":[25,41],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Контекстуальный профиль":[42,73],"#Наггар • Город Творцов#🎯 Интеллектуальная выжимка#Контекстуальный профиль#{1}":[43,73],"#Наггар • Город Творцов#📊 Статистика контента":[74,98],"#Наггар • Город Творцов#📊 Статистика контента#Распределение тем":[76,90],"#Наггар • Город Творцов#📊 Статистика контента#Распределение тем#{1}":[77,90],"#Наггар • Город Творцов#📊 Статистика контента#Структурный анализ":[91,98],"#Наггар • Город Творцов#📊 Статистика контента#Структурный анализ#{1}":[92,98],"#Наггар • Город Творцов#🎨 Семантическое плетение":[99,117],"#Наггар • Город Творцов#🎨 Семантическое плетение#Выявленные связи":[101,117],"#Наггар • Город Творцов#🎨 Семантическое плетение#Выявленные связи#{1}":[102,117]},"outlinks":[],"metadata":{"title":"Analysis: Наггар • Город Творцов","source":"https://gorodnaneve.com/nomadsouls/india/%d1%85%d0%b8%d0%bc%d0%b0%d1%87%d0%b0%d0%bb-%d0%bf%d1%80%d0%b0%d0%b4%d0%b5%d1%88/%d0%bd%d0%b0%d0%b3%d0%b3%d0%b0%d1%80/","content_type":"{% if content|match_count:\"Ψ|Phi|G_S|R_T\" > 2 %}MMSS_математика{% elif content|match_count:\"формул|уравнен\" > 1 %}научный{% else %}общий{% endif %}","key_terms":null,"math_patterns":"Наггар — древняя столица царей долины Куллу, пожалуй, одно из самых аутентичных мест в долине Куллу. Величественный форт постройки XV века, средневековые (XI — XIII в) храмы Кришны, Гаури Шанкар, Трипура Сундари Дэви и другие добавляют существенный колорит уютному горному городку, утопающему в зелени гималайских сосен.В Наггаре, в современной интерпретации, проявляется неразрывная духовная связь Индии и России – здесь долгое время жил и работал великий русский художник, исследователь и эзотерик Николай Константинович Рерих. В бывшей усадьбе теперь находится выставка подлинников картин пера великого визионера, экспозиция личных вещей и внутреннего убранства помещений.На месте кремации Николая Рериха, в тени липы, безошибочно узнаваемой на фоне пышущей гималайской флоры, установлена большая мемориальная плита, к которой водят на поклон экскурсии из местных школьников.В целом,бывшая резиденция Н.К. Рериха оставляет впечатление вырванного из общего контекста кусочка классической России конца девятнадцатого — начала двадцатого века. Русская культурная прошивка немедленно определяет незаметные для других параллели в отношении резиденции гималайского художника, тончайшими ментальными нитями связывая ее структуру и общую атмосферу с характерными музеями — заповедниками отечественных деятелей культуры дореволюционной поры на территории России, например, Ясной Поляной или Поленово. В двадцати минутах вверх от усадьбы расположены немногочисленные здания университета Урусвати, созданного Е.И. Рерих с целью изучения традиций Востока и обобщения информации, полученной в многочисленных экспедициях Рериха по малоисследованным уголкам центра Евразии. В одном из помещений представлена познавательная этнографическая экспозиция культуры и быта гималайских народов.Помимо знаменитого форта бывшего раджи Куллу, ныне используемого в качестве антиквариатной гостиницы, ресторана и музея, в Наггаре есть несколько приличных бюджетных гестхаусов. Поэтому, некоторые путешественники останавливаются здесь, надеясь избежать соприкосновения с реалиями шумной разношерстной туристической тусовки в Олд Манали или Вашиште.В Наггар можно попасть на локал басе из Манали ( 1 час) либо из столицы округа, города Куллу (2 часа), соединенного авиа и авто сообщением с другими крупными городами северо — запада полуострова.![](https://gorodnaneve.com/ru/uploads/2020/07/IMG_5325-%D0%BA%D0%BE%D0%BF%D0%B8%D1%8F.jpg)Мандир","complexity_score":"2426"},"task_lines":[],"last_embed":{"hash":"9eeh5n","at":1762028569095}},"smart_blocks:trash/Analysis Наггар • Город Творцов - 2025-10-29T044830+0300.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02992659,-0.03053989,0.00041638,-0.04005106,0.04893555,-0.03808025,0.04226721,0.09445385,0.00764854,-0.00661452,-0.04063363,-0.08615511,-0.00822749,0.04835249,-0.069214,-0.00882134,0.05936893,0.01112929,-0.03609546,-0.05906127,0.10262875,-0.03267927,0.00777031,-0.04709915,0.07559208,0.01556206,-0.03654441,-0.07422571,-0.08778703,-0.18756627,0.02009823,0.01336693,0.07657916,-0.0062405,-0.00710336,0.01048981,-0.03454141,0.06833029,-0.02071022,0.00947879,-0.03228863,-0.00463195,-0.00053374,0.01404115,0.00211441,-0.04019894,-0.03387419,-0.01585982,-0.03252039,-0.04712631,-0.05024481,0.00933977,0.00246277,-0.00677055,0.02282053,-0.02910446,0.0968883,0.00963493,0.02124806,0.04742314,0.06317208,-0.00190584,-0.25080109,0.00713087,0.10660888,0.05833912,-0.01854246,-0.00258206,-0.03559603,-0.01991532,-0.00396457,-0.01250998,0.00919947,0.