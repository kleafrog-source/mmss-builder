
"smart_sources:NOTSORTED/Untitled 9.md": {"path":"NOTSORTED/Untitled 9.md","embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06401551,-0.06412379,-0.06423868,-0.01912103,-0.02709773,0.01876022,-0.03735622,0.0248888,0.02683135,-0.01567925,0.01141159,-0.09340235,0.08081162,0.01704989,-0.05446282,-0.03331106,0.02130808,0.06157672,-0.08844717,0.00556796,0.06114789,-0.0241669,0.02152849,-0.01015024,0.01398129,0.07242413,0.02162362,-0.01330022,-0.07402536,-0.20763843,0.00034662,0.01641242,0.07152642,0.00391411,0.06290165,0.01427501,-0.01250696,0.03179741,-0.07947467,0.02370028,-0.03860227,-0.04028429,-0.008595,-0.02601341,-0.02440603,-0.04476473,-0.03682329,-0.00016418,-0.06770102,-0.04406446,-0.07245807,-0.0190119,-0.00869962,0.04980235,-0.01175025,0.06344074,0.04497872,0.03799814,0.09748406,0.02849969,0.06665786,-0.00718022,-0.21512406,0.03233749,0.05031472,0.00065783,-0.0251913,-0.07196054,0.08220463,-0.01147096,-0.0422745,0.04710418,0.03651422,0.05695837,0.02406932,-0.00011309,0.03077188,-0.063293,-0.01040735,-0.0393002,-0.01531439,0.06335264,-0.04011947,0.00178139,0.00070684,-0.03067402,0.02377181,-0.03704663,0.00268033,0.0074758,-0.02656217,0.00331016,0.0302792,0.02362871,-0.0198203,-0.06599949,-0.0158571,0.03757669,-0.01526487,0.08132142,-0.02113352,0.07023454,-0.02537411,-0.03997249,0.04887063,-0.04056557,-0.05275699,-0.06635342,-0.01916381,-0.00132242,-0.03640277,-0.0348266,0.04512789,-0.0472301,0.03925836,-0.00008658,0.0797854,0.05205571,0.03907369,-0.00041149,0.0271016,-0.00892872,0.03950249,0.02345971,0.06938221,0.01820797,-0.00294217,0.05968085,0.02049062,0.06899116,0.0307867,0.01473558,-0.01115702,0.03611838,0.02077993,0.01076965,-0.04046415,0.00385896,-0.00614949,-0.03293254,-0.03417406,-0.07882705,-0.07582904,-0.07670405,0.00525182,0.14666592,-0.02612358,-0.01728677,-0.0103116,0.00786707,-0.00153179,0.03278374,-0.08479719,-0.03984641,-0.01885852,-0.01095786,0.01927243,0.07799777,-0.07442702,0.0054598,0.02288827,-0.04657491,-0.00524229,0.20194355,-0.0091030