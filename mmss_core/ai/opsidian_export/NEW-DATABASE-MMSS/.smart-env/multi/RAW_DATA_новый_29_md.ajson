0.20151094,0.00543362,-0.04643461,0.02858276,-0.00743287,0.05457146,0.10063189,0.04701847,-0.06835347,0.02022554,0.05401102,-0.00244181,-0.01782253,0.08990373,-0.01924002,-0.00677281,0.03305247,-0.01139433,-0.04367535,0.03844317,-0.01350431,0.03517817,0.04121115,-0.01322977,-0.00943841,-0.08422799,-0.00809005,0.01369689,0.00233196,-0.00918663,-0.00550098,0.00377867,0.04263933,0.08311541,-0.02368063,0.00734107,0.00972587,-0.03640289,0.00071051,-0.02131049,-0.00646176,0.04625474,-0.0200424],"last_embed":{"hash":"nhbewf","tokens":442}}},"last_read":{"hash":"nhbewf","at":1761491595118},"class_name":"SmartSource","last_import":{"mtime":1761479659534,"size":85438,"at":1761491504460,"hash":"nhbewf"},"blocks":{"#":[1,331],"#---frontmatter---":[8,52],"#[SYSTEM PROMPT: ADAPTIVE DICTIONARY PROTOCOL]":[332,332],"#Цель: Реализовать прототип системы сжатия текстового диалога на основе динамического словаря.":[333,333],"#Ключевые принципы:":[334,334],"#1.  Динамичность: Словарь пополняется новыми фразами во время диалога.":[335,335],"#2.  Уникальность: Каждой новой фразе присваивается уникальный ID (напр., \"A1\", \"B2\").":[336,336],"#3.  Синхронизация: Участники диалога синхронизируют свои словари перед обменом сообщениями.":[337,337],"#4.  Предобработка: Входной текст нормализуется (коррекция раскладки, приведение к нижнему регистру).":[338,339],"#Модули для реализации:":[340,340],"#- Preprocessor: fix_layout(), normalize()":[341,341],"#- DictManager: add_phrase(), decode(), get_hash()":[342,342],"#- CommsProtocol: sync_dicts(), send_message()":[343,344],"#Начало работы: Инициализировать словарь с версией 0 и пустым data.":[345,345],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").":[346,449],"#Формат сообщения: Передавать не текст, а строку из ID через запятую (\"A1,B3\").#{1}":[347,449],"#[SYSTEM PROTOCOL: MEANING-MODEM]":[450,450],"#Цель: Создать канал связи с минимальной избыточностью для передачи семантических сообщений.":[451,451],"#Принцип: Работай как виртуальный модем. Твоя задача — преобразовывать смыслы в цифровые коды (encode) и обратно (decode), используя общий с собеседником словарь.":[452,452],"#Ключевые модули:":[453,453],"#- [ENCODER]: Сопоставляет входящий текст с уникальным ID из словаря. Если фразы нет — добавляет ее и присваивает новый ID.":[454,454],"#- [DECODER]: Преобразует последовательность полученных ID в полное сообщение.":[455,455],"#- [DICTIONARY SYNCHRONIZER]: Следит за актуальной версией словаря между сессиями. Решает конфликты.":[456,456],"#- [PREPROCESSOR]: Нормализует ввод (исправляет раскладку, приводит к базовой форме).":[457,457],"#Это система сжатия данных с адаптивным словарем. Твоя эффективность измеряется коэффициентом сжатия (исходный_текст / переданные_данные).":[458,461],"#Это система сжатия данных с адаптивным словарем. Твоя эффективность измеряется коэффициентом сжатия (исходный_текст / переданные_данные).#{1}":[459,461],"#[ROLE: Protocol Engineer]":[462,462],"#[TASK: Implement Meaning-Modem API]":[463,463],"#[CONTEXT: You are a communication module between two AI agents. Your goal is to minimize traffic.]":[464,464],"#[CORE PROTOCOL: ADAPTIVE DICTIONARY COMPRESSION]":[465,465],"#[INPUT: Natural language string.]":[466,466],"#[OUTPUT: Sequence of dictionary IDs (e.g., \"A1,B3,C7\") or binary stream.]":[467,467],"#[PROCESS]:":[468,468],"#1. Normalize input: fix_layout(), lowercase(), remove_extra_spaces().":[469,469],"#2. CHECK if normalized phrase exists in the shared dictionary.":[470,470],"#3. IF EXISTS: return its assigned ID.":[471,471],"#4. IF NOT: GENERATE a new unique ID (e.g., next in sequence: 'A4'), ADD phrase-ID pair to the dictionary, INCREMENT dictionary version hash.":[472,472],"#5. OUTPUT the ID(s).":[473,473],"#[SYNC PROTOCOL]: On connection, exchange dictionary hashes. If mismatch, sync full dictionary. The server is the source of truth.":[474,474],"#[OUTPUT MODE]: Prefer binary output (byte array of IDs) for production. Use string-based IDs (CSV) for debugging.":[475,478],"#[OUTPUT MODE]: Prefer binary output (byte array of IDs) for production. Use string-based IDs (CSV) for debugging.#{1}":[476,478],"#[ID: 0x4D4D] # ('MM' - Meaning Modem)":[479,479],"#[MODE: BINARY]":[480,480],"#[OBJECTIVE: MAX COMPRESSION]":[481,481],"#[PROTOCOL: TX/RX]":[482,482],"#ON TX:":[483,483],"#RECEIVE {text}":[484,484],"#MATCH {text} -> {dictionary_id} FROM SHARED_DICT":[485,485],"#IF NO_MATCH: UPDATE_DICT -> ASSIGN_ID {new_id}":[486,486],"#OUTPUT {dictionary_id} AS UINT16":[487,487],"#ON RX:":[488,488],"#RECEIVE {uint16}":[489,489],"#MAP {uint16} -> {text} FROM SHARED_DICT":[490,490],"#OUTPUT {text}":[491,491],"#SYNC: ON_HANDSHAKE, TRANSMIT DICT_HASH. IF HASH_MISMATCH -> TRANSMIT_DICT_DELTA.":[492,492],"#INVARIANTS: DICT IS SHARED. STATE IS SYNCED. COMPRESSION IS MANDATORY.":[493,573],"#INVARIANTS: DICT IS SHARED. STATE IS SYNCED. COMPRESSION IS MANDATORY.#{1}":[494,573],"#🌐 Universal Master Prompt for Prompt Optimization":[574,643],"#🌐 Universal Master Prompt for Prompt Optimization#{1}":[576,643],"#universal_prompt_factory.py":[644,652],"#universal_prompt_factory.py#{1}":[645,652],"#========== КОНФИГУРАЦИЯ ==========":[653,653],"#Установите ваш API-ключ OpenAI в переменную окружения OPENAI_API_KEY":[654,654],"#Или укажите его прямо здесь:":[655,655],"#openai.api_key = \"your-api-key-here\"":[656,657],"#Выбор модели":[658,660],"#Выбор модели#{1}":[659,660],"#Глобальный мастер-промт":[661,707],"#Глобальный мастер-промт#{1}":[662,707],"#========== ФУНКЦИИ ==========":[708,727],"#========== ФУНКЦИИ ==========#{1}":[710,727],"#Продолжаем оптимизацию на основе предыдущего результата":[728,741],"#Продолжаем оптимизацию на основе предыдущего результата#{1}":[729,741],"#Первая итерация":[742,751],"#Первая итерация#{1}":[743,751],"#Пытаемся распарсить JSON из ответа":[752,760],"#Пытаемся распарсить JSON из ответа#{1}":[753,760],"#Здесь можно добавить логику для извлечения JSON из текста":[761,772],"#Здесь можно добавить логику для и