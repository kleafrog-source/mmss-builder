# =====================================
# Mistral AI (Flask app + GEPA)
# =====================================
MISTRAL_API_KEY=<YOUR_MISTRAL_API_KEY>
MISTRAL_MODEL=mistral-small-latest

# =====================================
# Flask
# =====================================
SECRET_KEY=<CHANGE_ME>

# Environment Configuration Example
# =====================================

# =====================================
# PostgreSQL (Pezzo + Supertokens)
# =====================================
POSTGRES_USER=pezzo
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=pezzo

# =====================================
# ClickHouse (Analytics)
# =====================================
CLICKHOUSE_DB=default
CLICKHOUSE_USER=pezzo
CLICKHOUSE_PASSWORD=<CHANGE_ME>

# =====================================
# Redis (Cache + Queues)
# =====================================
REDIS_PASSWORD=<CHANGE_ME>

# =====================================
# Pezzo API
# =====================================
PEZZO_API_URL=http://localhost:3001
PEZZO_API_KEY=<YOUR_API_KEY>

# =====================================
# GEPA Configuration
# =====================================
GEPA_MCP_SERVER_URL=http://localhost:3003  # URL gepa-mcp сервера
GEPA_API_KEY=<YOUR_API_KEY>
GEPA_OPTIMIZATION_ITERATIONS=50
GEPA_POPULATION_SIZE=20

# =====================================
# MMSS Builder
# =====================================
MMSS_BUILDER_PATH=./mmss-builder
MMSS_OUTPUT_FORMAT=json
MMSS_AUTO_SYNC=true

# =====================================
# Optimizer Service
# =====================================
OPTIMIZER_HOST=0.0.0.0
OPTIMIZER_PORT=8000
OPTIMIZER_LOG_LEVEL=INFO

# =====================================
# MMSS Service
# =====================================
MMSS_HOST=0.0.0.0
MMSS_PORT=8001
MMSS_LOG_LEVEL=INFO

# =====================================
# Legacy prompt-db-local (for migration)
# =====================================
PROMPT_DB_LOCAL_PATH=./prompt-db-local
PROMPT_DB_FORMAT=json  # или sqlite

# =====================================
# Logging
# =====================================
LOG_LEVEL=INFO
LOG_FORMAT=json
